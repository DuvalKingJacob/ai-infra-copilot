# Optional: enables real OpenAI embeddings in `npm run embeddings:build`.
# If omitted, the script uses a deterministic local embedding fallback.
OPENAI_API_KEY=
EMBEDDING_MODEL=text-embedding-3-small

# Optional: used when testing the official Terraform MCP Server against HCP Terraform/TFE.
TFE_ADDRESS=https://app.terraform.io
TFE_TOKEN=

# Optional: production-shaped OIDC settings for a future backend.
OIDC_ISSUER=
OIDC_CLIENT_ID=
OIDC_AUDIENCE=

# Optional: production-shaped SpiceDB/AuthZed settings.
SPICEDB_HTTP_ENDPOINT=http://localhost:8443
SPICEDB_PRESHARED_KEY=dev-secret
